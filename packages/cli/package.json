{
  "name": "@dev-loop/cli",
  "version": "0.1.0",
  "description": "Command line interface for dev-loop",
  "license": "MIT",
  "type": "module",
  "bin": {
    "dev-loop": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@dev-loop/core": "0.1.0",
    "@dev-loop/ui": "0.1.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.4.0"
  }
}
