{
  "name": "@dev-loop/ui",
  "version": "0.1.0",
  "description": "Web UI package for dev-loop",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
