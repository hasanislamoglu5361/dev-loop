  },
  "dependencies": {
    "@dev-loop/core": "0.1.0",
    "fastify": "^4.28.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
