{
  "name": "@dev-loop/ui",
  "version": "0.1.0",
  "description": "Web UI package for dev-loop",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist dist-client tsconfig.tsbuildinfo && tsc -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@dev-loop/core": "0.1.0",
    "@fastify/websocket": "^6.0.1",
    "@tanstack/react-query": "^5.101.2",
    "fastify": "^4.29.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/react-test-renderer": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.4.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  }
}
